// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  image      String?
  emailVerified DateTime?
  provider   String?
  providerId String?
  createdAt  DateTime @default(now())

  licenses      License[]
  orders        Order[]
  paymentEvents PaymentEvent[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model License {
  id             String    @id @default(cuid())
  userId         String
  status         String    @default("active")
  paymentEventId String?
  trancheId      Int?
  pricePaidCents Int?
  monthlyUsage   Int       @default(0)
  usageResetAt   DateTime
  createdAt      DateTime  @default(now())
  user           User         @relation(fields: [userId], references: [id])
  paymentEvent   PaymentEvent? @relation(fields: [paymentEventId], references: [id])
  tranche        Tranche?     @relation(fields: [trancheId], references: [id])
  @@map("licenses")
}

model Tranche {
  id          Int      @id @default(autoincrement())
  name        String
  priceCents  Int
  capacity    Int
  soldCount   Int      @default(0)
  order       Int      @unique
  createdAt   DateTime @default(now())

  licenses    License[]

  @@map("tranches")
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  itemSlug       String
  status         String   @default("pending")
  deliveryMethod String
  downloadToken  String?
  createdAt      DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  stlJobs StlJob[]

  @@map("orders")
}

model StlJob {
  id           String    @id @default(cuid())
  orderId      String
  inputDir     String
  outputPath   String
  status       String    @default("queued")
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  expiresAt    DateTime
  filesDeleted Boolean   @default(false)

  order Order @relation(fields: [orderId], references: [id])

  @@map("stl_jobs")
}

model PaymentEvent {
  id              String   @id @default(cuid())
  userId          String?
  provider        String   @default("square")
  providerEventId String   @unique
  type            String
  amountCents     Int
  currency        String   @default("CAD")
  meta            Json
  createdAt       DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  licenses License[]

  @@map("payment_events")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}